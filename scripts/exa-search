#!/usr/bin/env python3
"""
Exa Search CLI - Semantic web search for AI agents
Install: pip install metaphor-python
Get API key: https://exa.ai (1000 searches/month free)
"""

import sys
import os
import json
import argparse

try:
    from metaphor_python import Metaphor
except ImportError:
    print("ERROR: Install metaphor-python first: pip install metaphor-python")
    sys.exit(1)

def main():
    parser = argparse.ArgumentParser(description="Exa semantic web search")
    parser.add_argument("query", help="Search query")
    parser.add_argument("--num", "-n", type=int, default=5, help="Number of results (default: 5)")
    parser.add_argument("--use-autoprompt", action="store_true", help="Let Exa optimize query")
    parser.add_argument("--type", "-t", choices=["auto", "keyword", "neural"], default="neural", help="Search type")
    parser.add_argument("--contents", "-c", action="store_true", help="Fetch page contents")
    parser.add_argument("--json", "-j", action="store_true", help="Output as JSON")
    
    args = parser.parse_args()
    
    api_key = os.environ.get("EXA_API_KEY")
    if not api_key:
        print("ERROR: Set EXA_API_KEY environment variable")
        print("Get free key at: https://exa.ai")
        sys.exit(1)
    
    client = Metaphor(api_key)
    
    try:
        response = client.search(
            args.query,
            num_results=args.num,
            use_autoprompt=args.use_autoprompt,
            type=args.type
        )
        
        results = []
        for result in response.results:
            entry = {
                "title": result.title,
                "url": result.url,
                "id": result.id,
                "published_date": str(result.published_date) if result.published_date else None,
                "author": result.author,
                "score": result.score
            }
            
            if args.contents:
                try:
                    contents = client.get_contents([result.id])
                    if contents and contents.results:
                        entry["content"] = contents.results[0].extract[:2000]  # First 2000 chars
                except:
                    pass
            
            results.append(entry)
        
        if args.json:
            print(json.dumps(results, indent=2))
        else:
            for i, r in enumerate(results, 1):
                print(f"\n--- Result {i} ---")
                print(f"Title: {r['title']}")
                print(f"URL: {r['url']}")
                if r.get('author'):
                    print(f"Author: {r['author']}")
                if r.get('published_date'):
                    print(f"Date: {r['published_date']}")
                if r.get('content'):
                    print(f"\nContent:\n{r['content'][:500]}...")
        
    except Exception as e:
        print(f"ERROR: {e}")
        sys.exit(1)

if __name__ == "__main__":
    main()