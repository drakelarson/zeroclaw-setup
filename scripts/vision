#!/usr/bin/env python3
"""
Local Vision Tool - Uses BLIP (tiny, ~500MB)
"""
import sys
import argparse
from PIL import Image
from transformers import BlipProcessor, BlipForConditionalGeneration

# Lazy load model
_model = None
_processor = None

def get_model():
    global _model, _processor
    if _model is None:
        _processor = BlipProcessor.from_pretrained("Salesforce/blip-image-captioning-base")
        _model = BlipForConditionalGeneration.from_pretrained("Salesforce/blip-image-captioning-base")
    return _model, _processor

def describe(image_path):
    """Generate image caption"""
    model, processor = get_model()
    image = Image.open(image_path).convert("RGB")
    inputs = processor(image, return_tensors="pt")
    out = model.generate(**inputs, max_length=100)
    caption = processor.decode(out[0], skip_special_tokens=True)
    print(caption)

def ask(image_path, question):
    """Answer question about image"""
    model, processor = get_model()
    image = Image.open(image_path).convert("RGB")
    inputs = processor(image, question, return_tensors="pt")
    out = model.generate(**inputs, max_length=100)
    answer = processor.decode(out[0], skip_special_tokens=True)
    print(answer)

def main():
    parser = argparse.ArgumentParser(description="Local vision tool")
    subparsers = parser.add_subparsers(dest="command", required=True)
    
    # describe command
    desc_parser = subparsers.add_parser("describe", help="Describe image")
    desc_parser.add_argument("image", help="Path to image")
    
    # ask command
    ask_parser = subparsers.add_parser("ask", help="Ask about image")
    ask_parser.add_argument("image", help="Path to image")
    ask_parser.add_argument("question", help="Question to ask")
    
    args = parser.parse_args()
    
    if args.command == "describe":
        describe(args.image)
    elif args.command == "ask":
        ask(args.image, args.question)

if __name__ == "__main__":
    main()