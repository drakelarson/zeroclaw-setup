#!/usr/bin/env python3
"""
Gemma-3-4b-it Vision via Google AI Studio
Usage: gemma-vision describe <image_path> [prompt]
       gemma-vision ask <image_path> "question"
"""
import sys
import os
import base64
import json
import requests

API_KEY = os.environ.get("GEMINI_API_KEY", "AIzaSyAY-SqgxyM88qjLF4aAjauIRTV_QoL8_sk")
MODEL = "gemma-3-4b-it"
API_URL = f"https://generativelanguage.googleapis.com/v1beta/models/{MODEL}:generateContent"

def encode_image(path):
    """Encode image to base64"""
    with open(path, "rb") as f:
        return base64.b64encode(f.read()).decode()

def get_mime_type(path):
    """Get MIME type from extension"""
    ext = path.lower().split(".")[-1]
    mime_map = {"jpg": "image/jpeg", "jpeg": "image/jpeg", "png": "image/png", "gif": "image/gif", "webp": "image/webp"}
    return mime_map.get(ext, "image/jpeg")

def analyze_image(image_path, prompt="Describe this image in detail"):
    """Send image to Google AI Studio and get response"""
    b64_data = encode_image(image_path)
    mime_type = get_mime_type(image_path)
    
    payload = {
        "contents": [{
            "parts": [
                {"text": prompt},
                {"inlineData": {"mimeType": mime_type, "data": b64_data}}
            ]
        }],
        "generationConfig": {
            "temperature": 0.4,
            "maxOutputTokens": 1024
        }
    }
    
    response = requests.post(
        f"{API_URL}?key={API_KEY}",
        headers={"Content-Type": "application/json"},
        json=payload,
        timeout=60
    )
    
    if response.status_code != 200:
        return f"Error: {response.status_code} - {response.text[:200]}"
    
    result = response.json()
    try:
        return result["candidates"][0]["content"]["parts"][0]["text"]
    except (KeyError, IndexError):
        return f"Error parsing response: {result}"

def main():
    if len(sys.argv) < 3:
        print("Usage: gemma-vision describe <image_path> [prompt]")
        print("       gemma-vision ask <image_path> \"question\"")
        sys.exit(1)
    
    command = sys.argv[1]
    image_path = sys.argv[2]
    
    if not os.path.exists(image_path):
        print(f"Error: Image not found: {image_path}")
        sys.exit(1)
    
    if command == "describe":
        prompt = sys.argv[3] if len(sys.argv) > 3 else "Describe this image in detail. What do you see?"
    elif command == "ask":
        if len(sys.argv) < 4:
            print("Error: 'ask' requires a question")
            sys.exit(1)
        prompt = sys.argv[3]
    else:
        print(f"Unknown command: {command}")
        sys.exit(1)
    
    result = analyze_image(image_path, prompt)
    print(result)

if __name__ == "__main__":
    main()